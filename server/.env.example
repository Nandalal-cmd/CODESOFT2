# ── Server ──────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ── Paytm Credentials ───────────────────────
# Get from: https://business.paytm.com → Developer → API Keys
PAYTM_MID=YOUR_PAYTM_MERCHANT_ID
PAYTM_MERCHANT_KEY=YOUR_PAYTM_MERCHANT_KEY
PAYTM_WEBSITE=WEBSTAGING       # Use DEFAULT for production
PAYTM_ENV=test                 # Use prod for production

# ── MongoDB (optional, replace in-memory store) ──
MONGODB_URI=mongodb://localhost:27017/fashionwear

# ── JWT Secret ──────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=12h

# ── Admin Credentials ───────────────────────
ADMIN_EMAIL=admin@fashionwear.in
ADMIN_PASSWORD=change_this_admin_password
